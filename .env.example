# Port overrides (host side). Defaults match dev servers.
BACKEND_PORT=8880
FRONTEND_PORT=3003

# Where the genome browser reads data from. Inside Docker this is /app/data;
# the path below is used by `make dev-backend`.
DATA_DIR=data

# Optional: enables ontology-ID lookups for QTLdb's PTO_name field via
# BioPortal (the Livestock Product Trait ontology isn't hosted on EBI OLS).
# Get a free key at https://bioportal.bioontology.org/account
# Without this, VT/CMO enrichment still works; only PTO IDs are skipped.
BIOPORTAL_API_KEY=
